CORTEX_HTTP=true
CORTEX_PORT=3179
# Admin token (optional when using per-user API keys via `hive-memory user create`).
# If set, this token grants admin access without a user account.
# If unset and no users exist, all requests are allowed (local dev mode).
CORTEX_AUTH_TOKEN=generate-a-random-token-here
CORTEX_DATA_DIR=/opt/hive-memory/data
CORTEX_ENRICHMENT=rule

# User management (multi-user access)
# Create a user:  hive-memory user create <name> [--email <email>]
# List users:     hive-memory user list
# Revoke a user:  hive-memory user revoke <user-id>
# API keys are prefixed with "hm_" and stored as SHA-256 hashes in SQLite.

# Slack connector (read-only sync)
SLACK_TOKEN=xoxb-...
SLACK_CHANNELS=C0...,C0...

# Slack bot (Bumble Bee interactive bot)
# Required Slack app scopes: app_mentions:read, chat:write
# Events API subscription URL: https://<host>/slack/events
SLACK_SIGNING_SECRET=...
SLACK_BOT_ENABLED=true

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_REPOS=org/repo1,org/repo2

# Google Calendar (optional)
GOOGLE_CALENDAR_CREDENTIALS=/opt/hive-memory/credentials.json
