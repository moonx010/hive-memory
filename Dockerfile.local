FROM node:22-slim AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:22-slim
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist ./dist
ENV CORTEX_HTTP=true
ENV CORTEX_DATA_DIR=/data
EXPOSE 3179
CMD ["node", "dist/index.js"]
